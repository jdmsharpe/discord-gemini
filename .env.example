# Environment variables example file - to be used as a template for .env file
BOT_TOKEN=your_value_here
GUILD_IDS=your_value_here
GEMINI_API_KEY=your_value_here

# Optional: Comma-separated File Search store IDs for /gemini chat file_search
# Create stores at https://aistudio.google.com/ or via the Gemini API
# GEMINI_FILE_SEARCH_STORE_IDS=fileSearchStores/store-1,fileSearchStores/store-2

# Optional: Show per-request cost and daily cost embeds in /gemini chat responses (default: true)
# SHOW_COST_EMBEDS=true